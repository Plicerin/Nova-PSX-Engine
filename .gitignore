# Build outputs
/build/

# Bundled SDK (auto-downloaded by build.ps1)
/external/

# Generated / imported assets (chamber assets are regenerated by
# tools/gen_source_assets.py; third-party assets are not committed)
/source_assets/

# Local, uncommitted asset overlay (e.g. third-party models). The tracked
# tools/assets_config.json now carries the game's assets; this overlay is only
# for entries you cannot commit.
tools/assets_config.local.json

# Python
__pycache__/
*.pyc

# Scratch
*.tmp.obj

# Archives (third-party model drops, etc.)
*.zip
*.rar

# Editor / tool local config
/.claude/
